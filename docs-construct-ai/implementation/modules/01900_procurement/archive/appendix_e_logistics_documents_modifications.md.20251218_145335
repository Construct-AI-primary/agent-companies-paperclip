#### Sorting Implementation

**Sort State Management:**
```javascript
const [sortField, setSortField] = useState('scope'); // Default sort by document name
const [sortDirection, setSortDirection] = useState('asc'); // asc or desc

const handleSort = (field) => {
  if (sortField === field) {
    // Toggle direction if same field
    setSortDirection(sortDirection === 'asc' ? 'desc' : 'asc');
  } else {
    // New field, start with ascending
    setSortField(field);
    setSortDirection('asc');
  }
};
```

**Sorting Logic:**
```javascript
const sortedDocuments = useMemo(() => {
  return [...filteredDocuments].sort((a, b) => {
    let aValue = getNestedValue(a, sortField);
    let bValue = getNestedValue(b, sortField);

    // Handle different data types
    if (typeof aValue === 'string') {
      aValue = aValue.toLowerCase();
      bValue = bValue.toLowerCase();
    }

    // Custom sorting for specific fields
    if (sortField === 'status') {
      const statusOrder = { 'draft': 1, 'in_transit': 2, 'delivered': 3, 'delayed': 4 };
      aValue = statusOrder[aValue] || 0;
      bValue = statusOrder[bValue] || 0;
    }

    if (sortField === 'priority') {
      const priorityOrder = { 'low': 1, 'medium': 2, 'high': 3, 'critical': 4 };
      aValue = priorityOrder[aValue] || 0;
      bValue = priorityOrder[bValue] || 0;
    }

    if (sortDirection === 'asc') {
      return aValue > bValue ? 1 : aValue < bValue ? -1 : 0;
    } else {
      return aValue < bValue ? 1 : aValue > bValue ? -1 : 0;
    }
  });
}, [filteredDocuments, sortField, sortDirection]);
```

