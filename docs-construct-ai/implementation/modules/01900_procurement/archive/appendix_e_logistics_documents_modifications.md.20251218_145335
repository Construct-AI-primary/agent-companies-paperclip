// Adjust sequence to optimize logistics document timing
const adjustSequenceForLogistics = async (sequence, logisticsDocuments, orderId) => {
  const procurementCompletionIndex = sequence.findIndex(doc =>
    doc.includes('Appendix A') || doc.includes('Completion')
  );

  // Ensure logistics documents come after procurement completion
  const adjustedSequence = [...sequence];
  logisticsDocuments.forEach(logisticsDoc => {
    const currentIndex = adjustedSequence.indexOf(logisticsDoc);
    if (currentIndex < procurementCompletionIndex) {
      // Move logistics document after procurement completion
      adjustedSequence.splice(currentIndex, 1);
      adjustedSequence.splice(procurementCompletionIndex + 1, 0, logisticsDoc);
    }
  });

  return adjustedSequence;
};
