    this.optimizationLearner = new OptimizationLearner();
  }

  // Complete logistics document workflow
  async executeLogisticsWorkflow(documentSpec, orderId) {
    console.log(`[IntegratedLogistics] Executing complete workflow for order ${orderId}`);

    // 1. Sequence-aware planning
    const sequencePosition = await this.sequenceManager.getLogisticsPosition(orderId);
    await this.waitForSequencePrerequisites(sequencePosition);

    // 2. AI-powered content generation
    const content = await this.generateLogisticsContent(documentSpec);

    // 3. Gantt timeline integration
    await this.ganttIntegrator.addLogisticsMilestone(content, orderId);

    // 4. My Tasks assignment with chatbot
    const task = await this.myTasksIntegrator.createLogisticsTask(content, orderId);

    // 5. HITL customs clearance workflow
    if (content.requiresCustomsClearance) {
      await this.hitlManager.scheduleCustomsClearance(content);
    }

    // 6. Optimization learning
    await this.optimizationLearner.recordExecution(content);

    return {
      content,
      task,
      ganttMilestone: await this.ganttIntegrator.getMilestone(content.id),
      hitlTask: content.requiresCustomsClearance ? 'scheduled' : null,
      optimizationInsights: await this.optimizationLearner.getInsights(content)
    };
  }

  // Generate logistics content with full integration
  async generateLogisticsContent(documentSpec) {
    // Select optimal API and prompt
    const apiConfig = await this.externalAPIManager.selectOptimalAPI(documentSpec);
    const prompt = await this.promptManager.selectOptimalPrompt(documentSpec);

    // Generate content
    const content = await this.externalAPIManager.generateContent(apiConfig, prompt, documentSpec);

    // Enhance with optimization insights
    const optimizedContent = await this.optimizationLearner.optimizeContent(content, documentSpec);

    return {
      ...optimizedContent,
      apiUsed: apiConfig.id,
      promptUsed: prompt.id,
      optimizationApplied: optimizedContent !== content
    };
  }
}
